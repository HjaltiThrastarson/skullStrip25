#!/usr/bin/env python
from __future__ import print_function

import os
import sys
import subprocess
import shutil

version = "1.0"
image = f"hjalti18/skullstrip:{version}"

def kill(msg, code=1):
    print(msg, file=sys.stderr)
    sys.exit(code)

# Sanity check
if shutil.which("docker") is None:
    kill("Cannot find docker in PATH. Make sure it is installed.")

if len(sys.argv) < 4:
    kill(f"Usage: {sys.argv[0]} <input_path> <output_path> <model_choice>\n"
         "model_choice: 0 = smaller model, 1 = large model")

# Resolve host paths
inp_host = os.path.realpath(os.path.abspath(sys.argv[1]))
out_host = os.path.realpath(os.path.abspath(sys.argv[2]))
model = sys.argv[3]

print(f"Input path is  {inp_host}")
print(f"Output path is {out_host}")

# Choose a single mount root that contains BOTH input and output
# (common parent directory)
mount_root = os.path.commonpath([os.path.dirname(inp_host), os.path.dirname(out_host)])
mount_root = os.path.realpath(os.path.abspath(mount_root))

# Compute container-visible paths under /work
def rel_to_mount(p):
    return os.path.relpath(p, start=mount_root).replace("\\", "/")

inp = "/work/" + rel_to_mount(inp_host)
out = "/work/" + rel_to_mount(out_host)

print(f"Mount root is  {mount_root}")
print(f"Container inp: {inp}")
print(f"Container out: {out}")

# Mount command (host -> container)
mounts = f'-v "{mount_root}:/work"'

# UID/GID on non-Windows only (Windows has no os.getuid)
user = ""
if os.name != "nt":
    user = "-u %s:%s" % (os.getuid(), os.getgid())

print(f"Running skull stripping method version {version} from Docker")

# Check if image exists (SynthStrip-style)
proc = subprocess.Popen(
    f'docker images -q {image}',
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
    shell=True,
    universal_newlines=True
)
stdout, stderr = proc.communicate()
if proc.returncode != 0:
    kill(stderr or "Error running docker command. Make sure Docker is installed.", proc.returncode)

# Pull if missing
if not stdout.strip():
    print(f"Docker image {image} is not installed. Downloading now (only needed once).")
    proc = subprocess.Popen(f"docker pull {image}", shell=True)
    proc.communicate()
    if proc.returncode != 0:
        kill("Error running docker pull.", proc.returncode)

# Run entrypoint
command = f'docker run --rm {user} {mounts} {image} "{inp}" "{out}" "{model}"'
print("Running:", command)

proc = subprocess.Popen(command, shell=True)
proc.communicate()

if proc.returncode == 137:
    print("Container ran out of memory (exit 137). Increase Docker RAM.")

sys.exit(proc.returncode)